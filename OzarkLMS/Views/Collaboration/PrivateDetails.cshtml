@model OzarkLMS.Models.PrivateChat
@using System.Security.Claims

@{
    ViewData["Title"] = "Private Chat";
    var currentUserId = int.Parse(User.FindFirstValue("UserId") ?? User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0");
    var otherUser = Model.User1Id == currentUserId ? Model.User2 : Model.User1;
    var otherUserId = otherUser?.Id ?? 0;
    var otherUserName = otherUser?.Username ?? "Unknown User";
    bool isAdmin = User.IsInRole("admin");
}

<style>
    /* Solid chat container */
    .chat-glass {
        background-color: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(20px);
    }
    .dark .chat-glass {
        background-color: rgba(15, 23, 42, 0.98);
    }
    
    /* Message bubble animations */
    .msg-bubble {
        animation: msg-in 0.2s ease-out;
    }
    @@keyframes msg-in {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Sent message style */
    .msg-sent {
        background: #004B87;
    }
    
    /* Scrollbar */
    .chat-scroll::-webkit-scrollbar { width: 6px; }
    .chat-scroll::-webkit-scrollbar-track { background: transparent; }
    .chat-scroll::-webkit-scrollbar-thumb { background: rgba(148, 163, 184, 0.3); border-radius: 3px; }
    .chat-scroll::-webkit-scrollbar-thumb:hover { background: rgba(148, 163, 184, 0.5); }
    
    /* Online pulse */
    .online-pulse {
        animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse-ring {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    /* Reply Styling */
    .reply-context {
        border-left: 3px solid #7C3AED;
        background: rgba(124, 58, 237, 0.05);
        border-radius: 8px;
    }
    .dark .reply-context {
        border-left-color: #A78BFA;
        background: rgba(167, 139, 250, 0.1);
    }
    .reply-preview-active {
        animation: slide-up 0.2s ease-out;
    }
    @@keyframes slide-up {
        from { transform: translateY(10px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

<div class="flex h-[calc(100dvh-64px)] bg-slate-50 dark:bg-slate-950 overflow-hidden overflow-x-hidden">
    
    <!-- Main Chat Area -->
    <div class="flex-1 flex flex-col relative w-full">
        
        <!-- Header -->
        <div class="px-3 sm:px-6 py-3 sm:py-4 chat-glass border-b border-slate-200/50 dark:border-slate-700/50 flex items-center justify-between z-20">
            <div class="flex items-center">
                <a asp-action="Index" class="mr-4 p-2.5 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl text-slate-500 dark:text-slate-400 transition-all">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                </a>
                
                <a asp-controller="Account" asp-action="Profile" asp-route-userId="@otherUserId" class="relative block cursor-pointer group">
                    @if(!string.IsNullOrEmpty(otherUser?.ProfilePictureUrl))
                    {
                        <img src="@otherUser?.ProfilePictureUrl" class="w-12 h-12 rounded-xl object-cover shadow-md ring-2 ring-white dark:ring-slate-800 transition-all" />
                    }
                    else
                    {
                        <div class="w-12 h-12 rounded-xl bg-purple-500 text-white flex items-center justify-center font-bold text-lg shadow-md">
                            @((otherUserName?.Length > 0) ? otherUserName.Substring(0, 1).ToUpper() : "?")
                        </div>
                    }
                </a>

                <div class="ml-4">
                    <h2 class="font-bold text-lg text-slate-800 dark:text-slate-100 flex items-center gap-2">
                        <a asp-controller="Account" asp-action="Profile" asp-route-userId="@otherUserId" class="hover:text-[#004B87] dark:hover:text-blue-400 transition-colors">@otherUserName</a>
                        <span class="px-2.5 py-0.5 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 text-[10px] font-bold uppercase tracking-wider">Private</span>
                    </h2>
                </div>
            </div>
            
            <!-- Actions placeholder -->
            <div class="flex items-center gap-2">
                <a asp-controller="Account" asp-action="Profile" asp-route-userId="@otherUserId" class="p-2.5 text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all" title="View Profile">
                    <i data-lucide="user" class="w-5 h-5"></i>
                </a>
            </div>
        </div>
        
        <!-- Messages Area -->
        <div class="flex-1 overflow-y-auto p-3 sm:p-6 space-y-4 bg-slate-50/50 dark:bg-slate-950 chat-scroll" id="messageContainer">
            @if(Model.Messages == null || !Model.Messages.Any())
            {
                <div class="flex flex-col items-center justify-center h-full text-center pb-20">
                    <div class="w-24 h-24 bg-purple-50 dark:bg-slate-800 text-purple-500 dark:text-purple-400 rounded-3xl flex items-center justify-center mb-6 shadow-inner">
                        <i data-lucide="message-circle-heart" class="w-12 h-12"></i>
                    </div>
                    <h3 class="text-slate-800 dark:text-slate-200 font-bold text-xl mb-2">Start the conversation</h3>
                    <p class="text-slate-400 dark:text-slate-500 max-w-xs">Say hello to @otherUserName!</p>
                </div>
            }
            else
            {
                @foreach(var msg in Model.Messages.OrderBy(m => m.SentDate))
                {
                    bool isMe = msg.SenderId == currentUserId;
                    bool hasAttachment = !string.IsNullOrEmpty(msg.AttachmentUrl);
                    bool isImg = hasAttachment && (msg.AttachmentContentType?.StartsWith("image/") ?? (msg.AttachmentUrl.EndsWith(".jpg") || msg.AttachmentUrl.EndsWith(".png") || msg.AttachmentUrl.EndsWith(".jpeg") || msg.AttachmentUrl.EndsWith(".gif")));
                    bool isDeleted = msg.IsDeleted;

                    <div class="flex w-full @(isMe ? "justify-end" : "justify-start") group/msg msg-bubble">
                        
                        <!-- Avatar (Received only) -->
                        @if(!isMe)
                        {
                            <a asp-controller="Account" asp-action="Profile" asp-route-userId="@msg.SenderId" class="mr-3 flex-shrink-0 self-end mb-1 cursor-pointer group/avatar">
                                @if(!string.IsNullOrEmpty(msg.Sender?.ProfilePictureUrl))
                                {
                                    <img src="@msg.Sender?.ProfilePictureUrl" class="w-9 h-9 rounded-xl object-cover shadow-sm bg-slate-200 dark:bg-slate-700 ring-2 ring-white dark:ring-slate-800 group-hover/avatar:ring-purple-500 transition-all" title="@(msg.Sender?.Username)" />
                                }
                                else
                                {
                                    <div class="w-9 h-9 rounded-xl bg-purple-500 text-white flex items-center justify-center text-xs font-bold shadow-sm" title="@(msg.Sender?.Username)">
                                        @((msg.Sender?.Username?.Length > 0) ? msg.Sender.Username.Substring(0,1).ToUpper() : "?")
                                    </div>
                                }
                            </a>
                        }

                        <!-- Message Content -->
                        <div class="flex flex-col max-w-[85%] md:max-w-[60%] @(isMe ? "items-end" : "items-start")">
                            
                            <div class="relative shadow-sm group/bubble @(isDeleted ? "bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-400 italic" : (isMe ? "msg-sent text-white" : "bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-200 border border-slate-100 dark:border-slate-700")) rounded-2xl @(isMe ? "rounded-tr-md" : "rounded-tl-md")">
                                
                                @if(isDeleted)
                                {
                                    <div class="px-4 py-3 text-sm flex items-center">
                                        <i data-lucide="trash-2" class="w-3.5 h-3.5 mr-2 opacity-50"></i> This message was deleted.
                                    </div>
                                }
                                else
                                {
                                    <!-- Reply Button -->
                                    <div class="absolute @(isMe ? "-left-10" : "-right-10") top-1/2 -translate-y-1/2 transition-all">
                                        <button onclick="setReply(@msg.Id, `@(msg.Sender?.Username ?? "Unknown")`, `@(msg.Message?.Replace("`", "\\`") ?? "")`)" class="p-2 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-full text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors" title="Reply">
                                            <i data-lucide="reply" class="w-4 h-4"></i>
                                        </button>
                                    </div>

                                    <!-- Parent Message Reference -->
                                    @if(msg.ParentMessage != null)
                                    {
                                        <div class="mx-3 mt-3 mb-1 p-2 text-xs reply-context @(isMe ? "opacity-90" : "") cursor-pointer" onclick="scrollToMessage(@msg.ParentMessageId)">
                                            <p class="font-bold text-purple-600 dark:text-purple-400 mb-0.5">@(msg.ParentMessage.Sender?.Username ?? "Unknown")</p>
                                            <p class="truncate opacity-80">@msg.ParentMessage.Message</p>
                                        </div>
                                    }
                                    <!-- Options Trigger (Hover) -->
                                    @if(isMe || isAdmin)
                                    {
                                        <div class="absolute top-2 right-2 opacity-0 group-hover/bubble:opacity-100 transition-opacity bg-black/20 rounded-full p-1 z-10 cursor-pointer backdrop-blur-sm" onclick="toggleMessageOptions(@msg.Id)">
                                            <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-white/90"></i>
                                        </div>
                                        
                                        <!-- Options Dropdown -->
                                        <div id="msgOptions-@msg.Id" class="hidden absolute top-8 right-2 bg-white dark:bg-slate-800 shadow-xl rounded-xl border border-slate-100 dark:border-slate-700 py-1 z-50 w-36 text-slate-800 dark:text-slate-200 animate-in fade-in slide-in-from-top-2 duration-150">
                                            @if(isMe)
                                            {
                                                <button onclick="enableEditMode(@msg.Id, `@msg.Message`)" class="w-full text-left px-4 py-2.5 text-sm hover:bg-slate-50 dark:hover:bg-slate-700 flex items-center transition-colors">
                                                    <i data-lucide="edit-2" class="w-4 h-4 mr-2 text-slate-400"></i> Edit
                                                </button>
                                            }
                                            <form id="deleteForm-@msg.Id" asp-action="DeletePrivateMessage" method="post">
                                                <input type="hidden" name="messageId" value="@msg.Id" />
                                                <button type="button" onclick="showDeleteModal(@msg.Id)" class="w-full text-left px-4 py-2.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 flex items-center transition-colors">
                                                    <i data-lucide="trash" class="w-4 h-4 mr-2"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    }

                                    <!-- File/Image -->
                                    @if(hasAttachment)
                                    {
                                        <div class="@(isImg ? "" : "p-3 border-b " + (isMe?"border-white/10":"border-slate-100 dark:border-slate-700"))">
                                            @if(isImg)
                                            {
                                                <div class="max-w-[300px] max-h-[300px] overflow-hidden rounded-xl">
                                                    <img src="@msg.AttachmentUrl" class="w-full h-full object-cover cursor-pointer hover:opacity-95 transition-opacity" onclick="openLightbox('@msg.AttachmentUrl')" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="flex items-center gap-3">
                                                    <div class="w-11 h-11 rounded-xl @(isMe ? "bg-white/20" : "bg-slate-100 dark:bg-slate-700") flex items-center justify-center flex-shrink-0">
                                                        @if(msg.AttachmentContentType?.Contains("pdf") == true) { <i data-lucide="file-text" class="w-5 h-5"></i> }
                                                        else if(msg.AttachmentContentType?.Contains("word") == true) { <i data-lucide="file-type" class="w-5 h-5"></i> }
                                                        else { <i data-lucide="file" class="w-5 h-5"></i> }
                                                    </div>
                                                    <div class="min-w-0">
                                                        <p class="text-sm font-medium truncate max-w-[150px]" title="@msg.AttachmentOriginalName">@(msg.AttachmentOriginalName ?? "Attachment")</p>
                                                        <div class="flex items-center text-[10px] opacity-70">
                                                            <span>@((msg.AttachmentSize / 1024.0).ToString("0.0")) KB</span>
                                                            <span class="mx-1">•</span>
                                                            <a href="@msg.AttachmentUrl" target="_blank" class="underline hover:decoration-2">Download</a>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    
                                    <!-- Text -->
                                    @if(!string.IsNullOrEmpty(msg.Message))
                                    {
                                        <div class="px-4 py-3" id="msgContent-@msg.Id">
                                            @if(msg.Message.StartsWith("[POST_SHARE]|"))
                                            {
                                                var parts = msg.Message.Split('|');
                                                if(parts.Length >= 5)
                                                {
                                                    var poster = parts[1];
                                                    var pId = parts[2];
                                                    var content = parts[3];
                                                    var link = parts[4];
                                                    
                                                    <div class="bg-white/10 dark:bg-slate-900/40 rounded-xl p-4 border border-white/20 dark:border-slate-700/50 shadow-inner">
                                                        <div class="flex items-center gap-2 mb-2">
                                                            <div class="w-6 h-6 rounded-md bg-purple-600 flex items-center justify-center">
                                                                <i data-lucide="share-2" class="w-3.5 h-3.5 text-white"></i>
                                                            </div>
                                                            <span class="text-[10px] font-black uppercase tracking-widest text-purple-600 dark:text-purple-400">Post Shared</span>
                                                        </div>
                                                        <p class="text-[11px] font-bold text-slate-500 dark:text-slate-400 mb-1">@@@poster</p>
                                                        <p class="text-sm line-clamp-2 text-slate-800 dark:text-slate-200 mb-3 leading-relaxed">@content</p>
                                                        <a href="@link" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-purple-600 text-white text-[10px] font-bold uppercase tracking-wider hover:opacity-90 transition-all shadow-md">
                                                            View Post
                                                            <i data-lucide="external-link" class="w-3 h-3"></i>
                                                        </a>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <p class="text-sm leading-relaxed whitespace-pre-wrap break-words">@msg.Message</p>
                                            }
                                        </div>
                                        <!-- Edit Form -->
                                        <form asp-action="EditPrivateMessage" method="post" id="editForm-@msg.Id" class="hidden px-3 py-3">
                                            <input type="hidden" name="messageId" value="@msg.Id" />
                                            <textarea name="newContent" class="w-full text-sm text-slate-800 dark:text-slate-200 rounded-xl p-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700" rows="2">@msg.Message</textarea>
                                            <div class="flex justify-end gap-2 mt-2">
                                                <button type="button" onclick="cancelEdit(@msg.Id)" class="text-xs text-white/80 hover:text-white font-medium">Cancel</button>
                                                <button type="submit" class="text-xs bg-white text-[#004B87] px-3 py-1.5 rounded-lg font-bold shadow-sm">Save</button>
                                            </div>
                                        </form>
                                    }
                                    
                                    <!-- Timestamp -->
                                    <div class="px-4 pb-2 text-[10px] w-full text-right @(isMe ? "text-blue-200" : "text-slate-400 dark:text-slate-500") flex items-center justify-end gap-1">
                                        @if(msg.LastEditedDate.HasValue)
                                        {
                                            <span class="italic">edited</span>
                                        }
                                        @msg.SentDate.ToLocalTime().ToShortTimeString()
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        
        <!-- Typing Indicator Container -->
        <div id="typingIndicatorContainer" class="px-6 py-2 hidden">
            <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-xs font-medium italic animate-pulse">
                <div class="flex gap-1">
                    <span class="w-1.5 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-bounce" style="animation-delay: 0s"></span>
                    <span class="w-1.5 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
                    <span class="w-1.5 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-bounce" style="animation-delay: 0.4s"></span>
                </div>
                <span id="typingUsersText">Someone is typing...</span>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 chat-glass border-t border-slate-200/50 dark:border-slate-700/50 z-20">
            <!-- Active Reply Preview -->
            <div id="replyPreviewBox" class="hidden mb-3 p-3 bg-slate-100 dark:bg-slate-800/80 rounded-xl border border-slate-200 dark:border-slate-700 flex items-center justify-between reply-preview-active">
                <div class="flex items-center gap-3 border-l-4 border-purple-500 dark:border-purple-400 pl-3 overflow-hidden">
                    <div class="min-w-0">
                        <p id="replyToUser" class="text-xs font-bold text-purple-600 dark:text-purple-400"></p>
                        <p id="replyToText" class="text-xs text-slate-500 dark:text-slate-400 truncate"></p>
                    </div>
                </div>
                <button type="button" onclick="cancelReply()" class="p-1.5 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-lg text-slate-400 transition-all">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>

            <form asp-action="PostPrivateMessage" method="post" enctype="multipart/form-data" class="flex flex-col gap-3" id="msgForm">
                <input type="hidden" name="chatId" value="@Model.Id" />
                <input type="hidden" name="parentMessageId" id="replyParentId" />
                
                <!-- File Preview -->
                <div id="filePreview" class="hidden px-4 py-3 bg-purple-50/50 dark:bg-purple-900/10 rounded-xl border border-purple-200 dark:border-purple-800 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-800 flex items-center justify-center">
                            <i data-lucide="file" class="w-4 h-4 text-purple-600 dark:text-purple-300"></i>
                        </div>
                        <span class="text-sm text-purple-700 dark:text-purple-300 font-medium truncate max-w-[200px]" id="fileNamePreview"></span>
                    </div>
                    <button type="button" onclick="clearFile()" class="text-slate-400 hover:text-red-500 dark:text-slate-500 dark:hover:text-red-400 transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
                
                <div class="flex items-end gap-2 sm:gap-3">
                    <button type="button" onclick="document.getElementById('fileInput').click()" class="p-2.5 sm:p-3 text-slate-400 hover:text-purple-600 hover:bg-purple-50 dark:text-slate-500 dark:hover:text-purple-400 dark:hover:bg-slate-800 rounded-xl transition-all flex-shrink-0">
                        <i data-lucide="paperclip" class="w-4 h-4 sm:w-5 sm:h-5"></i>
                    </button>
                    <input type="file" name="file" id="fileInput" class="hidden" onchange="previewFile()" />
                    
                    <div class="flex-1 bg-slate-100 dark:bg-slate-800 rounded-2xl focus-within:ring-2 focus-within:ring-purple-500 dark:focus-within:ring-purple-400 focus-within:bg-white dark:focus-within:bg-slate-900 transition-all flex items-center px-3 sm:px-4 py-0 sm:py-1 border border-transparent focus-within:border-purple-200 dark:focus-within:border-purple-900">
                        <textarea id="msgTextarea" name="message" class="w-full bg-transparent border-0 focus:ring-0 py-2.5 sm:py-3 text-[13px] sm:text-sm text-slate-700 dark:text-slate-200 placeholder-slate-500 dark:placeholder-slate-400 resize-none max-h-32 outline-none" rows="1" placeholder="Message @otherUserName..." oninput="autoResize(this); notifyTyping();" onkeydown="submitOnEnter(event)"></textarea>
                    </div>
                    
                    <button type="submit" class="p-2.5 sm:p-3.5 bg-purple-500 hover:bg-purple-600 text-white rounded-xl hover:shadow-lg transition-all flex-shrink-0">
                        <i data-lucide="send" class="w-4 h-4 sm:w-5 sm:h-5"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Image Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex items-center justify-center p-4 backdrop-blur-sm">
    <div class="relative w-full h-full flex items-center justify-center">
        <img id="lightboxImg" src="" class="max-w-full max-h-full rounded-2xl shadow-2xl object-contain" />
        <button onclick="closeLightbox()" class="absolute top-6 right-6 text-white hover:text-slate-300 bg-white/10 hover:bg-white/20 p-3 rounded-xl transition-all backdrop-blur-sm">
            <i data-lucide="x" class="w-8 h-8"></i>
        </button>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-[100] bg-black/50 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-[95%] sm:w-full max-w-sm mx-auto p-6 animate-in zoom-in-95 duration-150">
        <div class="flex items-center justify-center w-14 h-14 bg-red-100 dark:bg-red-900/30 rounded-full mx-auto mb-4">
            <i data-lucide="trash-2" class="w-7 h-7 text-red-600 dark:text-red-400"></i>
        </div>
        <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100 text-center mb-2">Delete Message</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 text-center mb-6">Are you sure you want to delete this message? This action cannot be undone.</p>
        <div class="flex gap-3">
            <button onclick="hideDeleteModal()" class="flex-1 px-4 py-2.5 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-xl font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">Cancel</button>
            <button id="confirmDeleteBtn" onclick="confirmDelete()" class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl font-medium hover:bg-red-700 transition-colors">Delete</button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    function scrollBottom() {
        var container = document.getElementById("messageContainer");
        container.scrollTop = container.scrollHeight;
    }
    window.onload = scrollBottom;
    
    function autoResize(textarea) {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
    }

    function submitOnEnter(event) {
        if (event.key === "Enter" && !event.shiftKey) {
            event.preventDefault();
            document.getElementById("msgForm").dispatchEvent(new Event("submit"));
        }
    }
    
    function previewFile() {
        const input = document.getElementById('fileInput');
        if (input.files.length > 0) {
            document.getElementById('fileNamePreview').textContent = input.files[0].name;
            document.getElementById('filePreview').classList.remove('hidden');
        }
    }
    
    function clearFile() {
        document.getElementById('fileInput').value = '';
        document.getElementById('filePreview').classList.add('hidden');
    }
    
    function openLightbox(url) {
        document.getElementById('lightboxImg').src = url;
        document.getElementById('lightbox').classList.remove('hidden');
    }
    
    function closeLightbox() {
        document.getElementById('lightbox').classList.add('hidden');
    }
    
    // Delete Modal Functions
    let pendingDeleteMsgId = null;
    function showDeleteModal(msgId) {
        pendingDeleteMsgId = msgId;
        document.getElementById('deleteModal').classList.remove('hidden');
        document.querySelectorAll('[id^=msgOptions-]').forEach(el => el.classList.add('hidden'));
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }
    function hideDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
        pendingDeleteMsgId = null;
    }
    function confirmDelete() {
        if (pendingDeleteMsgId) {
            document.getElementById(`deleteForm-${pendingDeleteMsgId}`).submit();
        }
    }
    
    // Message Editing Logic
    function toggleMessageOptions(msgId) {
        const menu = document.getElementById(`msgOptions-${msgId}`);
        document.querySelectorAll('[id^=msgOptions-]').forEach(el => {
            if(el.id !== `msgOptions-${msgId}`) el.classList.add('hidden');
        });
        menu.classList.toggle('hidden');
    }
    
    function enableEditMode(msgId, currentContent) {
        document.getElementById(`msgContent-${msgId}`).classList.add('hidden');
        document.getElementById(`editForm-${msgId}`).classList.remove('hidden');
        document.getElementById(`msgOptions-${msgId}`).classList.add('hidden');
    }
    
    function cancelEdit(msgId) {
        document.getElementById(`msgContent-${msgId}`).classList.remove('hidden');
        document.getElementById(`editForm-${msgId}`).classList.add('hidden');
    }
    
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.group\\/bubble')) {
            document.querySelectorAll('[id^=msgOptions-]').forEach(el => el.classList.add('hidden'));
        }
    });

    // Message Reply Logic
    let currentReplyId = null;
    function setReply(msgId, username, text) {
        currentReplyId = msgId;
        document.getElementById('replyParentId').value = msgId;
        document.getElementById('replyToUser').textContent = username;
        document.getElementById('replyToText').textContent = text;
        document.getElementById('replyPreviewBox').classList.remove('hidden');
        document.getElementById('msgTextarea').focus();
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }
    
    function cancelReply() {
        currentReplyId = null;
        document.getElementById('replyParentId').value = '';
        document.getElementById('replyPreviewBox').classList.add('hidden');
    }

    function scrollToMessage(msgId) {
        const el = document.getElementById(`msg-container-${msgId}`);
        if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            el.classList.add('ring-2', 'ring-purple-500', 'dark:ring-purple-400', 'ring-offset-2');
            setTimeout(() => el.classList.remove('ring-2', 'ring-purple-500', 'dark:ring-purple-400', 'ring-offset-2'), 2000);
        }
    }

    // Real-Time Chat & Form Submission Logic
    const currentUserId = @currentUserId;
    const currentChatId = "@Model.Id";
    const currentUsername = "@(User.Identity?.Name ?? "User")";

    const chatConnection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    chatConnection.start().then(() => {
        chatConnection.invoke("JoinChat", "private_" + currentChatId);
    }).catch(err => console.error(err.toString()));

    const msgForm = document.getElementById('msgForm');
    const msgTextarea = document.getElementById('msgTextarea');

    if(msgForm) {
        msgForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(msgForm);
            const msgContent = formData.get('message');
            const fileContent = formData.get('file');

            if (!msgContent?.trim() && (!fileContent || fileContent.size === 0)) return;

            // Clear input visually immediately
            msgTextarea.value = '';
            msgTextarea.style.height = 'auto';
            clearFile();
            cancelReply();

            try {
                const response = await fetch(msgForm.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });
                
                if(!response.ok) {
                    console.error("Failed to send message.");
                }
            } catch (error) {
                console.error("Error submitting message form:", error);
            }
        });
    }

    chatConnection.on("ReceiveMessage", function (data) {
        if(data.chatId.toString() !== currentChatId) return;
        
        const isMe = data.senderId === currentUserId;
        const msgList = document.getElementById("messageContainer");

        if(!msgList) return;

        const noMsgState = msgList.querySelector('.text-center.pb-20');
        if(noMsgState) noMsgState.remove();

        const timeString = new Date(data.sentDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});

        let replyHtml = '';
        if (data.parentMessage) {
            replyHtml = `<div class="mx-3 mt-3 mb-1 p-2 text-xs reply-context ${isMe ? "opacity-90" : ""} cursor-pointer" onclick="scrollToMessage(${data.parentMessage.id})">
                            <p class="font-bold text-purple-600 dark:text-purple-400 mb-0.5">${data.parentMessage.senderUsername}</p>
                            <p class="truncate opacity-80">${data.parentMessage.message || ""}</p>
                         </div>`;
        }

        let avatarHtml = '';
        if(!isMe) {
            if(data.senderProfilePictureUrl) {
                avatarHtml = `<a href="/Account/Profile?userId=${data.senderId}" class="mr-3 flex-shrink-0 self-end mb-1 cursor-pointer group/avatar">
                                <img src="${data.senderProfilePictureUrl}" class="w-9 h-9 rounded-xl object-cover shadow-sm bg-slate-200 dark:bg-slate-700 ring-2 ring-white dark:ring-slate-800 group-hover/avatar:ring-purple-500 transition-all" title="${data.senderUsername}" />
                              </a>`;
            } else {
                avatarHtml = `<a href="/Account/Profile?userId=${data.senderId}" class="mr-3 flex-shrink-0 self-end mb-1 cursor-pointer group/avatar">
                                <div class="w-9 h-9 rounded-xl bg-purple-500 text-white flex items-center justify-center text-xs font-bold shadow-sm" title="${data.senderUsername}">
                                    ${(data.senderUsername || "?")[0].toUpperCase()}
                                </div>
                              </a>`;
            }
        }

        let attachmentHtml = '';
        if(data.attachmentUrl) {
            const isImg = data.attachmentContentType?.startsWith("image/") || ["jpg","png","jpeg","gif"].some(ext => data.attachmentUrl.toLowerCase().endsWith(ext));
            if(isImg) {
                attachmentHtml = `<div class="max-w-[300px] max-h-[300px] overflow-hidden rounded-xl">
                                    <img src="${data.attachmentUrl}" class="w-full h-full object-cover cursor-pointer hover:opacity-95 transition-opacity" onclick="openLightbox('${data.attachmentUrl}')" />
                                  </div>`;
            } else {
                attachmentHtml = `<div class="p-3 border-b ${isMe ? 'border-white/10' : 'border-slate-100 dark:border-slate-700'}">
                                    <div class="flex items-center gap-3">
                                        <div class="w-11 h-11 rounded-xl ${isMe ? 'bg-white/20' : 'bg-slate-100 dark:bg-slate-700'} flex items-center justify-center flex-shrink-0">
                                            <i data-lucide="file" class="w-5 h-5"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <p class="text-sm font-medium truncate max-w-[150px]">${data.attachmentOriginalName || 'Attachment'}</p>
                                            <div class="flex items-center text-[10px] opacity-70">
                                                <span>${(data.attachmentSize / 1024).toFixed(1)} KB</span>
                                                <span class="mx-1">•</span>
                                                <a href="${data.attachmentUrl}" target="_blank" class="underline hover:decoration-2">Download</a>
                                            </div>
                                        </div>
                                    </div>
                                  </div>`;
            }
        }

        let textHtml = '';
        if(data.message) {
            textHtml = `<div class="px-4 py-3"><p class="text-sm leading-relaxed whitespace-pre-wrap break-words">${data.message}</p></div>`;
        }

        const msgHtml = `
            <div class="flex w-full ${isMe ? 'justify-end' : 'justify-start'} group/msg msg-bubble" id="msg-container-${data.id}">
                ${avatarHtml}
                <div class="flex flex-col max-w-[85%] md:max-w-[60%] ${isMe ? 'items-end' : 'items-start'}">
                    <div class="relative shadow-sm group/bubble ${isMe ? 'msg-sent text-white rounded-2xl rounded-tr-md' : 'bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-200 border border-slate-100 dark:border-slate-700 rounded-2xl rounded-tl-md'}">
                        
                        <!-- Reply Button -->
                        <div class="absolute ${isMe ? "-left-10" : "-right-10"} top-1/2 -translate-y-1/2 opacity-0 group-hover/msg:opacity-100 transition-all">
                            <button onclick="setReply(${data.id}, '${data.senderUsername}', '${(data.message || "").replace(/'/g, "\\'")}')" class="p-2 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-full text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">
                                <i data-lucide="reply" class="w-4 h-4"></i>
                            </button>
                        </div>

                        ${replyHtml}
                        ${attachmentHtml}
                        ${textHtml}
                        <div class="px-4 pb-2 text-[10px] w-full text-right ${isMe ? 'text-blue-200' : 'text-slate-400 dark:text-slate-500'} flex items-center justify-end gap-1">
                            ${timeString}
                        </div>
                    </div>
                </div>
            </div>
        `;

        msgList.insertAdjacentHTML('beforeend', msgHtml);
        
        // Scroll to bottom
        msgList.scrollTop = msgList.scrollHeight;
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });

    let typingTimeout;
    let isTyping = false;

    function notifyTyping() {
        if (!isTyping) {
            isTyping = true;
            chatConnection.invoke("SendTyping", "private_" + currentChatId, currentUsername).catch(err => console.error(err));
        }
        
        clearTimeout(typingTimeout);
        typingTimeout = setTimeout(() => {
            isTyping = false;
        }, 2000);
    }

    let hideIndicatorTimeout;
    chatConnection.on("UserTyping", function(username) {
        const container = document.getElementById('typingIndicatorContainer');
        const textSpan = document.getElementById('typingUsersText');
        
        if(container && textSpan) {
            textSpan.textContent = username + " is typing...";
            container.classList.remove('hidden');
            
            clearTimeout(hideIndicatorTimeout);
            hideIndicatorTimeout = setTimeout(() => {
                 container.classList.add('hidden');
            }, 2500);
        }
    });

</script>
