@{
    ViewData["Title"] = "Create Module";
}

<div class="p-8 max-w-[600px] mx-auto">
    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-lg border border-gray-200 dark:border-slate-800 overflow-hidden">
        <div class="p-6 border-b border-gray-100 dark:border-slate-800 bg-gray-50 dark:bg-slate-800/50">
             <h1 class="text-xl font-bold text-[#004B87] dark:text-blue-400">Create New Module</h1>
        </div>
        
        <form asp-action="Create" enctype="multipart/form-data" class="p-8 space-y-6">
            <input type="hidden" name="CourseId" value="@ViewBag.CourseId" />
            
            <div>
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Module Title</label>
                <input name="Title" class="w-full rounded-lg border-gray-300 dark:border-slate-700 dark:bg-slate-800 dark:text-white shadow-sm focus:border-[#004B87] dark:focus:border-blue-500 focus:ring-[#004B87] dark:focus:ring-blue-500" placeholder="e.g. Unit 1: Introduction" required />
            </div>

            <!-- Optional Initial Content -->
            <div class="bg-blue-50 dark:bg-slate-800/50 p-4 rounded-lg border border-blue-100 dark:border-slate-700">
                <h3 class="text-sm font-bold text-[#004B87] dark:text-blue-400 mb-3">Add Content (Optional)</h3>
                
                <div class="mb-4">
                    <label class="block text-xs font-bold text-slate-600 dark:text-slate-400 mb-2">Upload File</label>
                    <input type="file" name="file" class="w-full text-sm text-slate-500 dark:text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-100 dark:file:bg-slate-700 file:text-[#004B87] dark:file:text-blue-400 hover:file:bg-blue-200 dark:hover:file:bg-slate-600 transition-colors"/>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-600 dark:text-slate-400 mb-2">Display Mode</label>
                    <div class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-4">
                        <label class="flex items-center group cursor-pointer">
                            <input type="radio" name="displayMode" value="link" checked class="text-[#004B87] dark:text-blue-500 focus:ring-[#004B87] dark:focus:ring-blue-500 bg-white dark:bg-slate-900 border-gray-300 dark:border-slate-600" />
                            <span class="ml-2 text-sm text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">List View (Download/Link)</span>
                        </label>
                        <label class="flex items-center group cursor-pointer">
                            <input type="radio" name="displayMode" value="embed" class="text-[#004B87] dark:text-blue-500 focus:ring-[#004B87] dark:focus:ring-blue-500 bg-white dark:bg-slate-900 border-gray-300 dark:border-slate-600" />
                            <span class="ml-2 text-sm text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">Direct View (Embed)</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end items-center sm:space-x-4 pt-6 border-t border-gray-100 dark:border-slate-800 gap-4 sm:gap-0">
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@ViewBag.CourseId" class="w-full sm:w-auto text-center px-6 py-2 text-slate-500 dark:text-slate-400 font-bold hover:text-slate-700 dark:hover:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-all">Cancel</a>
                <button type="submit" class="w-full sm:w-auto bg-[#004B87] dark:bg-blue-600 text-white px-6 py-2 rounded-lg font-bold hover:bg-[#003d6e] dark:hover:bg-blue-700 shadow-lg shadow-blue-900/20 dark:shadow-none transition-all">
                    Create Module
                </button>
            </div>
        </form>
    </div>
</div>
